			"name": "[concat(parameters('factoryName'), '/DS_SQL_TargetOutput')]",
			"type": "Microsoft.DataFactory/factories/datasets",
			"apiVersion": "2018-06-01",
			"properties": {
				"linkedServiceName": {
					"referenceName": "[parameters('LS_SQLDatabase')]",
					"type": "LinkedServiceReference"
				},
				"annotations": [],
				"type": "AzureSqlTable",
				"schema": [
					{
						"name": "ID",
						"type": "int",
						"precision": 10
					},
					{
						"name": "Employee_name",
						"type": "varchar"
					},
					{
						"name": "StoreID",
						"type": "varchar"
					},
					{
						"name": "Week",
						"type": "int",
						"precision": 10
					},
					{
						"name": "E_Regular_hours",
						"type": "float",
						"precision": 15
					},
					{
						"name": "E_overtime_hours",

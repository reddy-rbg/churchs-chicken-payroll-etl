{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "churchs-payroll-adf"
		},
		"LS_DataLake_accountKey": {
			"type": "secureString",
			"metadata": "Secure string for 'accountKey' of 'LS_DataLake'"
		},
		"LS_Databricks_accessToken": {
			"type": "secureString",
			"metadata": "Secure string for 'accessToken' of 'LS_Databricks'"
		},
		"LS_SQLDatabase_password": {
			"type": "secureString",
			"metadata": "Secure string for 'password' of 'LS_SQLDatabase'"
		},
		"LS_DataLake_properties_typeProperties_url": {
			"type": "string",
			"defaultValue": "https://churchspayrollstorage.dfs.core.windows.net/"
		},
		"LS_Databricks_properties_typeProperties_existingClusterId": {
			"type": "string",
			"defaultValue": "0423-213928-79g9i270"
		},
		"LS_KeyVault_properties_typeProperties_baseUrl": {
			"type": "string",
			"defaultValue": "https://churchs-payroll-kv.vault.azure.net/"
		},
		"LS_SQLDatabase_properties_typeProperties_server": {
			"type": "string",
			"defaultValue": "churchs-payroll-server.database.windows.net"
		},
		"LS_SQLDatabase_properties_typeProperties_database": {
			"type": "string",
			"defaultValue": "churchs-payroll-db"
		},
		"LS_SQLDatabase_properties_typeProperties_userName": {
			"type": "string",
			"defaultValue": "payrolladmin"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "churchs-payroll-adf_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"LS_DataLake_accountKey": {
						"value": "[parameters('LS_DataLake_accountKey')]"
					},
					"LS_Databricks_accessToken": {
						"value": "[parameters('LS_Databricks_accessToken')]"
					},
					"LS_SQLDatabase_password": {
						"value": "[parameters('LS_SQLDatabase_password')]"
					},
					"LS_DataLake_properties_typeProperties_url": {
						"value": "[parameters('LS_DataLake_properties_typeProperties_url')]"
					},
					"LS_Databricks_properties_typeProperties_existingClusterId": {
						"value": "[parameters('LS_Databricks_properties_typeProperties_existingClusterId')]"
					},
					"LS_KeyVault_properties_typeProperties_baseUrl": {
						"value": "[parameters('LS_KeyVault_properties_typeProperties_baseUrl')]"
					},
					"LS_SQLDatabase_properties_typeProperties_server": {
						"value": "[parameters('LS_SQLDatabase_properties_typeProperties_server')]"
					},
					"LS_SQLDatabase_properties_typeProperties_database": {
						"value": "[parameters('LS_SQLDatabase_properties_typeProperties_database')]"
					},
					"LS_SQLDatabase_properties_typeProperties_userName": {
						"value": "[parameters('LS_SQLDatabase_properties_typeProperties_userName')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}